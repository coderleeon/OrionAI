# OrionAI — Environment Variables
# Copy this file to .env and fill in your values.
# The system runs in MOCK mode (no real LLM calls) if OPENAI_API_KEY is not set.

# ── LLM ──────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key-here
MODEL_NAME=gpt-4o-mini
MODEL_TEMPERATURE=0.2
MODEL_MAX_TOKENS=2048

# ── Orchestration ─────────────────────────────────────────────────────────────
MAX_RETRIES=3
CRITIC_CONFIDENCE_THRESHOLD=0.70

# ── Redis (optional — falls back to in-memory if unavailable) ─────────────────
REDIS_URL=redis://localhost:6379/0
SESSION_TTL_SECONDS=3600

# ── Cache ─────────────────────────────────────────────────────────────────────
CACHE_ENABLED=true
CACHE_TTL_SECONDS=300

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/orion.log

# ── API Server ────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
